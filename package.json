{
  "name": "bucomax-dashboard",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "node --disable-warning=DEP0169 ./node_modules/next/dist/bin/next dev",
    "build": "next build",
    "build:vercel": "prisma migrate deploy --schema=packages/prisma/schema.prisma && next build",
    "start": "node --disable-warning=DEP0169 ./node_modules/next/dist/bin/next start",
    "lint": "eslint",
    "db:generate": "prisma generate --schema=packages/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=packages/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=packages/prisma/schema.prisma",
    "db:push": "prisma db push --schema=packages/prisma/schema.prisma",
    "db:seed": "prisma db seed",
    "db:purge:tenants-pathways": "tsx scripts/db-purge-keep-tenants-and-pathways.ts",
    "db:studio": "prisma studio --schema=packages/prisma/schema.prisma",
    "postinstall": "prisma generate --schema=packages/prisma/schema.prisma && patch-package",
    "load:test": "node scripts/load-and-security/run-load.mjs",
    "load:heavy": "node scripts/load-and-security/run-load-heavy.mjs",
    "load:stampede": "node scripts/load-and-security/run-stampede.mjs",
    "security:probe": "node scripts/load-and-security/run-security-probes.mjs",
    "security:rate-limit": "node scripts/load-and-security/run-rate-limit-suite.mjs",
    "stress:all": "node scripts/load-and-security/run-battery.mjs",
    "audit:api-latency": "node scripts/load-and-security/run-api-latency-audit.mjs",
    "audit:api-latency:stress": "LATENCY_AUDIT_ITERATIONS=70 LATENCY_AUDIT_CONCURRENCY=40 LATENCY_AUDIT_WARMUP=10 LATENCY_AUDIT_TIMEOUT_MS=300000 node scripts/load-and-security/run-api-latency-audit.mjs",
    "audit:prisma-queries": "tsx scripts/load-and-security/run-prisma-slow-probe.ts",
    "audit:prisma-queries:stress": "PRISMA_PROBE_ROUNDS=24 PRISMA_PROBE_CONCURRENCY=20 tsx scripts/load-and-security/run-prisma-slow-probe.ts",
    "test:session-cookie": "tsx scripts/load-and-security/issue-load-test-session.ts",
    "test:e2e": "playwright test",
    "test:e2e:patient-self-register": "playwright test e2e/patient-self-register.spec.ts",
    "e2e:issue-self-register-invite": "tsx scripts/e2e/issue-patient-self-register-invite.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google-cloud/storage": "^7.18.0",
    "@hookform/resolvers": "^5.2.2",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.8.2",
    "@scalar/nextjs-api-reference": "^0.8.23",
    "@vercel/speed-insights": "^2.0.0",
    "@xyflow/react": "^12.10.1",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-auth": "^4.24.11",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "react-qr-code": "^2.0.18",
    "resend": "^4.0.1",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autocannon": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "patch-package": "^8.0.1",
    "prisma": "^6.8.2",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx packages/prisma/seed.ts"
  }
}
