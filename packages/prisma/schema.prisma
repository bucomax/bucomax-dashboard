generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum GlobalRole {
  user
  super_admin
}

enum TenantRole {
  tenant_admin
  tenant_user
}

enum AuthTokenPurpose {
  PASSWORD_RESET
  INVITE_SET_PASSWORD
}

enum NotificationType {
  sla_critical
  sla_warning
  stage_transition
  new_patient
  checklist_complete
  patient_portal_file_pending
}

/** Eventos de auditoria agregados na linha do tempo do paciente (LGPD: payload sem conteúdo clínico). */
enum AuditEventType {
  STAGE_TRANSITION
  FILE_UPLOADED_TO_CLIENT
  SELF_REGISTER_COMPLETED
  PATIENT_PORTAL_FILE_SUBMITTED
  PATIENT_PORTAL_FILE_APPROVED
  PATIENT_PORTAL_FILE_REJECTED
  PATIENT_PORTAL_PASSWORD_SET
  STAFF_LOGIN_SUCCESS
  STAFF_LOGIN_FAILED
  STAFF_PASSWORD_CHANGED
  STAFF_PASSWORD_RESET
  PATIENT_PORTAL_SESSION_CREATED
  PATIENT_PORTAL_LINK_GENERATED
  PATIENT_CREATED
  PATIENT_UPDATED
  PATIENT_DELETED
  PATIENT_PATHWAY_STARTED
  PATIENT_PATHWAY_COMPLETED
  FILE_DOWNLOADED_BY_STAFF
  FILE_DOWNLOADED_BY_PATIENT
  CHECKLIST_ITEM_TOGGLED
  FILE_DELETED
  PATIENT_PORTAL_LOGIN_FAILED
  PATIENT_CONSENT_GIVEN
  AUDIT_EXPORT_GENERATED
  WHATSAPP_DISPATCH_QUEUED
  WHATSAPP_DISPATCH_SENT
  WHATSAPP_DISPATCH_DELIVERED
  WHATSAPP_DISPATCH_READ
  WHATSAPP_DISPATCH_FAILED
  WHATSAPP_PATIENT_CONFIRMED
}

/** Validação na ficha quando o paciente envia arquivo pelo portal. */
enum PatientPortalFileReviewStatus {
  NOT_APPLICABLE
  PENDING
  APPROVED
  REJECTED
}

/** Parentesco do responsável legal (menor). */
enum GuardianRelationship {
  mother
  father
  legal_guardian
  other
}

/** Preferência declarada de canal de contato (campo informativo / roteamento futuro). */
enum PatientPreferredChannel {
  email
  whatsapp
  sms
  none
}

model User {
  id                                String                        @id @default(cuid())
  name                              String?
  email                             String                        @unique
  emailVerified                     DateTime?
  image                             String?
  passwordHash                      String?
  globalRole                        GlobalRole                    @default(user)
  activeTenantId                    String?
  activeTenant                      Tenant?                       @relation("UserActiveTenant", fields: [activeTenantId], references: [id], onDelete: SetNull)
  accounts                          Account[]
  sessions                          Session[]
  memberships                       TenantMembership[]
  authTokens                        UserAuthToken[]
  fileAssets                        FileAsset[]
  stageTransitions                  StageTransition[]             @relation("StageTransitionActor")
  forcedStageTransitions            StageTransition[]             @relation("StageTransitionForcedBy")
  checklistCompletions              PatientPathwayChecklistItem[] @relation("ChecklistCompletedBy")
  patientNotesAuthored              PatientNote[]                 @relation("PatientNoteAuthor")
  assignedClients                   Client[]                      @relation("ClientAssignedTo")
  notifications                     Notification[]
  patientSelfRegisterInvitesCreated PatientSelfRegisterInvite[]   @relation("PatientSelfRegisterInviteCreator")
  clientsSoftDeleted                Client[]                      @relation("ClientDeletedBy")
  auditEvents                       AuditEvent[]                  @relation("AuditEventActor")
  /** Responsável padrão da etapa (template), sincronizado do editor ao publicar. */
  defaultAssigneePathwayStages      PathwayStage[]                @relation("PathwayStageDefaultAssignee")
  /** Responsável pela etapa atual na instância do paciente na jornada. */
  currentStageAssigneePatientPathways PatientPathway[]            @relation("PatientPathwayCurrentStageAssignee")
  deletedAt                         DateTime?
  createdAt                         DateTime                      @default(now())
  updatedAt                         DateTime                      @updatedAt
}

model UserAuthToken {
  id        String           @id @default(cuid())
  token     String           @unique
  userId    String
  tenantId  String?
  purpose   AuthTokenPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tenant {
  id                         String                      @id @default(cuid())
  name                       String
  slug                       String                      @unique
  /**
   * Quando false, APIs de negócio e troca de contexto recusam este tenant (exceto gestão por super_admin).
   */
  isActive                   Boolean                     @default(true)
  taxId                      String?
  phone                      String?
  addressLine                String?
  city                       String?
  postalCode                 String?
  affiliatedHospitals        String?                     @db.Text
  notifyCriticalAlerts       Boolean                     @default(true)
  notifySurgeryReminders     Boolean                     @default(true)
  notifyNewPatients          Boolean                     @default(true)
  notifyWeeklyReport         Boolean                     @default(true)
  notifyDocumentDelivery     Boolean                     @default(true)

  // === WhatsApp Business API ===
  whatsappEnabled            Boolean                     @default(false)
  whatsappPhoneNumberId      String?
  whatsappBusinessAccountId  String?
  /** AES-256-GCM encrypted access token; decrypted only at dispatch time. */
  whatsappAccessTokenEnc     String?                     @db.Text
  whatsappWebhookVerifyToken String?
  /** ISO timestamp of last successful API health check. */
  whatsappVerifiedAt         DateTime?

  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  memberships                TenantMembership[]
  activeUsers                User[]                      @relation("UserActiveTenant")
  authTokens                 UserAuthToken[]
  clients                    Client[]
  fileAssets                 FileAsset[]
  carePathways               CarePathway[]
  patientPathways            PatientPathway[]
  opmeSuppliers              OpmeSupplier[]
  patientNotes               PatientNote[]
  notifications              Notification[]
  patientSelfRegisterInvites PatientSelfRegisterInvite[]
  auditEvents                AuditEvent[]
  channelDispatches          ChannelDispatch[]
}

/**
 * Paciente / cliente da clínica (escopo por tenant).
 */
model Client {
  id               String           @id @default(cuid())
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  phone            String
  email            String?
  caseDescription  String?          @db.Text
  documentId       String?

  // === Endereço ===
  postalCode      String?
  addressLine     String?
  addressNumber   String?
  addressComp     String?
  neighborhood    String?
  city            String?
  state           String?            // UF (2 chars)

  // === Menor de idade / Responsável ===
  isMinor            Boolean          @default(false)
  birthDate          DateTime?        @db.Date
  guardianRelationship GuardianRelationship?
  guardianName       String?
  guardianDocumentId String?          // CPF do responsável (11 dígitos)
  guardianPhone      String?
  guardianEmail      String?
  emergencyContactName  String?
  emergencyContactPhone String?
  preferredChannel      PatientPreferredChannel @default(none)
  portalPasswordHash String?
  /// Última vez que a senha do portal foi definida ou alterada (invalida cookies com `pwdv` desatualizado).
  portalPasswordChangedAt DateTime?
  assignedToUserId String?
  assignedTo       User?            @relation("ClientAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  opmeSupplierId   String?
  opmeSupplier     OpmeSupplier?    @relation(fields: [opmeSupplierId], references: [id], onDelete: SetNull)
  deletedAt        DateTime?
  /**
   * Usuário que executou o soft delete (auditoria).
   */
  deletedByUserId  String?
  deletedBy        User?            @relation("ClientDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  files            FileAsset[]
  patientPathways            PatientPathway[]
  patientNotes               PatientNote[]
  patientSelfRegisterInvites PatientSelfRegisterInvite[]
  patientPortalLinkTokens      PatientPortalLinkToken[]
  patientPortalOtpChallenges PatientPortalOtpChallenge[]
  auditEvents                  AuditEvent[]
  channelDispatches            ChannelDispatch[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([deletedByUserId])
}

model PatientPortalLinkToken {
  id        String    @id @default(cuid())
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  /** Uso único: preenchido após o primeiro exchange bem-sucedido quando `singleUse` é true. */
  usedAt     DateTime?
  singleUse Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@index([clientId])
}

/**
 * Código OTP (CPF + e-mail/WhatsApp) para sessão do portal, escopo tenant.
 */
model PatientPortalOtpChallenge {
  id         String    @id @default(cuid())
  clientId   String
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenantId   String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId, clientId])
  @@index([createdAt])
}

/**
 * Link temporário (QR) para o paciente preencher o próprio cadastro na clínica.
 * Um token por convite; após uso (`usedAt`) não pode ser reutilizado.
 * `clientId` opcional: convite amarra ao paciente já existente (atualiza cadastro em vez de criar novo).
 */
model PatientSelfRegisterInvite {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  token           String    @unique
  expiresAt       DateTime
  usedAt          DateTime?
  createdByUserId String
  createdBy       User      @relation("PatientSelfRegisterInviteCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  clientId        String?
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())

  @@index([tenantId])
  @@index([tenantId, clientId])
}

/**
 * Nota clínica/operacional dedicada do paciente.
 */
model PatientNote {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  authorUserId String
  author       User     @relation("PatientNoteAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  content      String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, clientId, createdAt])
  @@index([authorUserId])
}

/**
 * Fornecedor OPME (catálogo por tenant).
 */
model OpmeSupplier {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clients              Client[]
  tenantMemberships    TenantMembership[]

  @@index([tenantId])
}

/**
 * Jornada clínica (modelo por tenant).
 */
model CarePathway {
  id          String           @id @default(cuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  versions    PathwayVersion[]
  patients    PatientPathway[]

  @@index([tenantId])
}

/**
 * Versão do grafo (React Flow) + publicação.
 */
model PathwayVersion {
  id           String           @id @default(cuid())
  pathwayId    String
  pathway      CarePathway      @relation(fields: [pathwayId], references: [id], onDelete: Cascade)
  version      Int
  graphJson    Json
  published    Boolean          @default(false)
  createdAt    DateTime         @default(now())
  stages       PathwayStage[]
  patientCases PatientPathway[]

  @@unique([pathwayId, version])
  @@index([pathwayId, published])
}

/**
 * Etapa materializada (sincronizada ao publicar versão).
 */
model PathwayStage {
  id                String         @id @default(cuid())
  pathwayVersionId  String
  pathwayVersion    PathwayVersion @relation(fields: [pathwayVersionId], references: [id], onDelete: Cascade)
  stageKey          String
  name              String
  sortOrder         Int            @default(0)
  patientMessage    String?        @db.Text
  /**
   * Dias na etapa acima do qual UI pode marcar “atenção” (Bucomax / SLA).
   */
  alertWarningDays  Int?
  /**
   * Dias na etapa acima do qual UI pode marcar “crítico”.
   */
  alertCriticalDays Int?
  /**
   * Usuário padrão responsável por esta etapa (membro do tenant). Pode ser sobrescrito na instância.
   * Mantido alinhado ao primeiro elemento de `defaultAssigneeUserIds` para relação Prisma e índices.
   */
  defaultAssigneeUserId String?
  defaultAssigneeUser   User?          @relation("PathwayStageDefaultAssignee", fields: [defaultAssigneeUserId], references: [id], onDelete: SetNull)
  /**
   * Membros da equipe considerados responsáveis padrão desta etapa (ordem preservada). O primeiro válido no tenant tende a virar `currentStageAssignee` ao iniciar/transicionar.
   */
  defaultAssigneeUserIds String[] @default([])

  currentPatients PatientPathway[]            @relation("PatientCurrentStage")
  transitionsFrom StageTransition[]           @relation("TransitionFrom")
  transitionsTo   StageTransition[]           @relation("TransitionTo")
  stageDocuments  StageDocument[]
  checklistItems  PathwayStageChecklistItem[]

  @@unique([pathwayVersionId, stageKey])
  @@index([pathwayVersionId, sortOrder])
  @@index([defaultAssigneeUserId])
}

/**
 * Documento do pacote de uma etapa (N:N etapa ↔ arquivo na biblioteca / R2).
 */
model StageDocument {
  id             String       @id @default(cuid())
  pathwayStageId String
  pathwayStage   PathwayStage @relation(fields: [pathwayStageId], references: [id], onDelete: Cascade)
  fileAssetId    String
  fileAsset      FileAsset    @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)
  sortOrder      Int          @default(0)

  @@unique([pathwayStageId, fileAssetId])
  @@index([pathwayStageId, sortOrder])
}

/**
 * Item de checklist configurado para uma etapa publicada.
 */
model PathwayStageChecklistItem {
  id              String                        @id @default(cuid())
  pathwayStageId  String
  pathwayStage    PathwayStage                  @relation(fields: [pathwayStageId], references: [id], onDelete: Cascade)
  label           String
  sortOrder       Int                           @default(0)
  /**
   * Se true, a transição para outra etapa exige este item concluído (salvo override auditado na API).
   */
  requiredForTransition Boolean               @default(false)
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
  progressEntries PatientPathwayChecklistItem[]

  @@index([pathwayStageId, sortOrder])
}

/**
 * Paciente vinculado a uma versão publicada + etapa atual.
 */
model PatientPathway {
  id               String                        @id @default(cuid())
  tenantId         String
  tenant           Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId         String
  client           Client                        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pathwayId        String
  pathway          CarePathway                   @relation(fields: [pathwayId], references: [id], onDelete: Restrict)
  pathwayVersionId String
  pathwayVersion   PathwayVersion                @relation(fields: [pathwayVersionId], references: [id], onDelete: Restrict)
  currentStageId   String
  currentStage     PathwayStage                  @relation("PatientCurrentStage", fields: [currentStageId], references: [id], onDelete: Restrict)
  /**
   * Responsável pela etapa atual (notificações escopadas na Fase 2). Herda do estágio ou do cliente.
   */
  currentStageAssigneeUserId String?
  currentStageAssignee       User?                     @relation("PatientPathwayCurrentStageAssignee", fields: [currentStageAssigneeUserId], references: [id], onDelete: SetNull)
  /**
   * Momento em que o paciente entrou na etapa atual (para “dias na fase” e alertas).
   */
  enteredStageAt   DateTime                      @default(now())
  /**
   * Quando preenchido, a jornada está concluída (não aparece mais no kanban ativo).
   */
  completedAt      DateTime?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  transitions      StageTransition[]
  checklistItems   PatientPathwayChecklistItem[]
  auditEvents      AuditEvent[]

  @@index([tenantId])
  @@index([clientId])
  @@index([pathwayId])
  @@index([pathwayVersionId, currentStageId])
  @@index([currentStageAssigneeUserId])
}

/**
 * Progresso do checklist por paciente dentro da jornada.
 */
model PatientPathwayChecklistItem {
  id                String                    @id @default(cuid())
  patientPathwayId  String
  patientPathway    PatientPathway            @relation(fields: [patientPathwayId], references: [id], onDelete: Cascade)
  checklistItemId   String
  checklistItem     PathwayStageChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  completedAt       DateTime?
  completedByUserId String?
  completedByUser   User?                     @relation("ChecklistCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@unique([patientPathwayId, checklistItemId])
  @@index([patientPathwayId])
  @@index([checklistItemId])
}

/**
 * Auditoria de mudança de etapa + stub de dispatch (WhatsApp / IA).
 */
model StageTransition {
  id               String         @id @default(cuid())
  patientPathwayId String
  patientPathway   PatientPathway @relation(fields: [patientPathwayId], references: [id], onDelete: Cascade)
  fromStageId      String?
  fromStage        PathwayStage?  @relation("TransitionFrom", fields: [fromStageId], references: [id], onDelete: SetNull)
  toStageId        String
  toStage          PathwayStage   @relation("TransitionTo", fields: [toStageId], references: [id], onDelete: Restrict)
  actorUserId      String
  actor            User           @relation("StageTransitionActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  note             String?        @db.Text
  /** Justificativa quando a transição ignora checklist obrigatório incompleto (`force` na API). */
  ruleOverrideReason String?      @db.Text
  forcedByUserId   String?
  forcedByUser     User?          @relation("StageTransitionForcedBy", fields: [forcedByUserId], references: [id], onDelete: SetNull)
  dispatchStub     Json?

  createdAt          DateTime          @default(now())
  channelDispatches  ChannelDispatch[]

  @@index([patientPathwayId])
  @@index([forcedByUserId])
}

/**
 * Linha do tempo unificada (transição, upload, cadastro público, etc.).
 * `payload` deve referenciar IDs e metadados mínimos — evitar duplicar texto clínico.
 */
model AuditEvent {
  id               String           @id @default(cuid())
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /** Null em eventos só de tenant/equipe (ex.: login staff) sem paciente associado. */
  clientId         String?
  client           Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  patientPathwayId String?
  patientPathway   PatientPathway?    @relation(fields: [patientPathwayId], references: [id], onDelete: SetNull)
  actorUserId      String?
  actor            User?            @relation("AuditEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  type             AuditEventType
  payload          Json
  createdAt        DateTime         @default(now())

  @@index([tenantId, clientId, createdAt])
}

/**
 * Metadados de arquivo no R2 (upload via URL pré-assinada).
 */
model FileAsset {
  id                          String                       @id @default(cuid())
  tenantId                    String
  tenant                      Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  r2Key                       String                       @unique
  fileName                    String
  mimeType                    String
  sizeBytes                   Int
  /** Null quando o envio partiu do portal do paciente (sem usuário staff). */
  uploadedById                String?
  uploadedBy                  User?                        @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  clientId                    String?
  client                      Client?                      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  patientPortalReviewStatus   PatientPortalFileReviewStatus @default(NOT_APPLICABLE)
  /** SHA-256 do objeto no bucket após upload (integridade; null se GCS indisponível ou falha ao ler). */
  sha256Hash                  String?
  createdAt                   DateTime                     @default(now())
  stageDocuments              StageDocument[]

  @@index([tenantId])
  @@index([clientId])
  @@index([tenantId, clientId, patientPortalReviewStatus])
}

model TenantMembership {
  id       String     @id @default(cuid())
  userId   String
  tenantId String
  role     TenantRole @default(tenant_user)
  /**
   * Quando true (e papel `tenant_user`): só enxerga pacientes com `Client.assignedToUserId` = si mesmo.
   * `tenant_admin` e `super_admin` ignoram este flag na política.
   */
  restrictedToAssignedOnly Boolean @default(false)
  /**
   * Se preenchido (e papel `tenant_user`): só enxerga pacientes com esse fornecedor OPME.
   * Deve referenciar `OpmeSupplier` do mesmo tenant (validado na API ao atualizar membership).
   */
  linkedOpmeSupplierId String?
  linkedOpmeSupplier   OpmeSupplier? @relation(fields: [linkedOpmeSupplierId], references: [id], onDelete: SetNull)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([linkedOpmeSupplierId])
  @@unique([userId, tenantId])
}

/**
 * Notificação in-app persistida por usuário.
 */
model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt, createdAt])
  @@index([tenantId, createdAt])
}

// ---------------------------------------------------------------------------
// WhatsApp / Channel Dispatch
// ---------------------------------------------------------------------------

enum DispatchChannel {
  WHATSAPP
}

enum DispatchStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  CONFIRMED
  FAILED
}

/**
 * Registro de envio por canal externo (WhatsApp, futuro: email, SMS).
 * Cada documento enviado gera um ChannelDispatch; a mensagem interativa
 * de confirmação também gera seu próprio registro.
 */
model ChannelDispatch {
  id                  String          @id @default(cuid())
  tenantId            String
  tenant              Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stageTransitionId   String
  stageTransition     StageTransition @relation(fields: [stageTransitionId], references: [id], onDelete: Cascade)
  clientId            String
  client              Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  channel             DispatchChannel
  status              DispatchStatus  @default(QUEUED)
  /** WhatsApp message ID (wamid) returned by Meta API. */
  externalMessageId   String?
  /** Phone number the message was sent to (E.164 format). */
  recipientPhone      String
  /** Document file name — null for the interactive confirmation message. */
  documentFileName    String?
  /** R2/GCS key of the document sent. */
  documentR2Key       String?
  /** Presigned URL generated at dispatch time (short TTL). */
  presignedUrl        String?         @db.Text
  /** Error details from Meta API or internal failures. */
  errorDetail         String?         @db.Text
  /** Timestamp when Meta reported 'sent'. */
  sentAt              DateTime?
  /** Timestamp when Meta reported 'delivered'. */
  deliveredAt         DateTime?
  /** Timestamp when Meta reported 'read'. */
  readAt              DateTime?
  /** Timestamp when patient clicked confirmation button. */
  confirmedAt         DateTime?
  /** Button payload received from patient (e.g. "received" or "help"). */
  confirmationPayload String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([tenantId, createdAt])
  @@index([stageTransitionId])
  @@index([externalMessageId])
  @@index([clientId, createdAt])
}
