# Copie para .env.local ou .env (não commitar segredos)

# Postgres
# Em produção (ex.: Vercel): defina DATABASE_URL e DIRECT_URL no painel do projeto.
# O build roda `prisma migrate deploy` antes do Next; com pooler (Neon/Supabase), use URL direta em DIRECT_URL.
DATABASE_URL="postgresql://bucomax:bucomax@localhost:5432/bucomax?schema=public"
DIRECT_URL="postgresql://bucomax:bucomax@localhost:5432/bucomax?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="troque-com-openssl-rand-base64-32"

# Base URL do app (fetch do browser para /api). Em produção (ex.: Vercel): https://seu-projeto.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Redis — filas BullMQ e SSE; Upstash em produção (URL rediss://). Sem REDIS_URL, notificações rodam inline.
REDIS_URL=

# Cliente: AES para estado persistido no localStorage (mín. 32 caracteres; público no bundle)
NEXT_PUBLIC_APP_PERSIST_SECRET="troque-com-string-longa-32-chars-minimo!!"

# Opcional: forçar a não subir o worker BullMQ no mesmo processo (ex.: deploy não serverless com Redis)
# DISABLE_NOTIFICATION_WORKER=true

# URL pública nos links dos e-mails (Resend) — mesmo host em dev
APP_PUBLIC_URL="http://localhost:3000"

# Resend — https://resend.com
# Sem domínio verificado: use a API key "Onboarding" e EMAIL_FROM com onboarding@resend.dev (não use @resend.com).
# Com domínio verificado no painel: Bucomax <noreply@seudominio.com>
RESEND_API_KEY=
EMAIL_FROM="Bucomax <onboarding@resend.dev>"

# Cloudflare R2 (S3-compatible) — mesmo bucket de teste do kaber.ai no .env local, se aplicável
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ─── Redis / BullMQ (opcional — sem essa variável roda em modo inline) ───
# Dev local (docker-compose): redis://localhost:6379
# Vercel / serverless: deixe VAZIO ou não defina para usar modo inline (sem fila, sem SSE)
# Upstash / managed Redis: redis://:<password>@<host>:<port>
REDIS_URL=
